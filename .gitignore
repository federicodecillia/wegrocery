# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Clasp credentials
.clasprc.json

# IDE
.idea/
.vscode/

# Claude Code local config
.claude/

# Old clasp config backup
.clasp.json.old

# project-local MCP config (per-machine, not for the public repo)
.mcp.json
